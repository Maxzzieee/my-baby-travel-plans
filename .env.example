# Copy to .env and fill in. Required for the AI "Read with AI" plan extraction.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional — backend port (defaults to 8787, matches the Vite proxy)
# PORT=8787

# Supabase — shared realtime board + photo/meme wall.
# Project Settings → API. The anon key is meant for frontend use (public).
# VITE_ vars are bundled into the client, so set the same two in Vercel too.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-public-key...
