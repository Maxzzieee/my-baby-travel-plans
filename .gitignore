# dependencies
node_modules/

# package-lock is intentionally not committed: a committed lockfile containing
# esbuild's cross-platform optional packages triggers an npm dedup crash
# ("Invalid Version:") during reify on clean CI installs (Vercel/Netlify).
# A lockfile-free `npm install` resolves cleanly.
package-lock.json

# build output
dist/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# editor / os
.DS_Store
.vscode/
.idea/
*.local

# env
.env
.env.*
!.env.example
